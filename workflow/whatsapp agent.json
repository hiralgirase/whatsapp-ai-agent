      "parameters": {
        "content": "## WhatsApp Trigger  \n**- Receives incoming user messages from WhatsApp\n- Requires:\n  • Valid webhook URL (Production URL)\n  • Correct verify token (must match Meta)\n  • Active workflow (IMPORTANT)\n\n",
        "height": 336,
